# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="mysql://app_user:change_me@127.0.0.1:3306/kaniz_global_trade"

# ============================================================
# REDIS
# ============================================================
REDIS_URL="redis://127.0.0.1:6379"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ============================================================
# JWT
# ============================================================
JWT_ACCESS_SECRET="replace-with-a-64-plus-character-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-64-plus-character-random-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
JWT_REFRESH_REMEMBER_DAYS="30"
JWT_REFRESH_SESSION_DAYS="1"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Kaniz Global Trade"
NEXT_PUBLIC_APP_DESCRIPTION="Global B2B Export Import Marketplace"
NODE_ENV="development"
PRISMA_LOG_QUERIES="false"

# ============================================================
# SEEDING AND DEMO ACCESS
# ============================================================
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
ENABLE_DEMO_ACCOUNTS="false"
SEED_SUPPLIER_EMAIL=""
SEED_SUPPLIER_PASSWORD=""
SEED_BUYER_EMAIL=""
SEED_BUYER_PASSWORD=""
NEXT_PUBLIC_ENABLE_DEMO_LOGIN="false"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=""
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=""
NEXT_PUBLIC_DEMO_SUPPLIER_EMAIL=""
NEXT_PUBLIC_DEMO_SUPPLIER_PASSWORD=""
NEXT_PUBLIC_DEMO_BUYER_EMAIL=""
NEXT_PUBLIC_DEMO_BUYER_PASSWORD=""

# ============================================================
# SOCKET.IO
# ============================================================
SOCKET_URL="http://localhost:3001"
SOCKET_PORT="3001"

# ============================================================
# STORAGE (CLOUDFLARE R2 / AWS S3)
# ============================================================
S3_ACCESS_KEY="replace-with-your-storage-access-key"
S3_SECRET_KEY="replace-with-your-storage-secret-key"
S3_BUCKET="replace-with-your-storage-bucket"
S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
S3_REGION="auto"
NEXT_PUBLIC_CDN_URL="https://cdn.example.com"

# ============================================================
# GOOGLE AI SEARCH
# ============================================================
GOOGLE_AI_SEARCH_ENABLED="false"
GOOGLE_GEMINI_API_KEY=""
GOOGLE_AI_TEXT_MODEL="gemini-2.0-flash"
GOOGLE_AI_IMAGE_MODEL="gemini-2.0-flash"
