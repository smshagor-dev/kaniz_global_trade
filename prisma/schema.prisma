  user          User                   @relation(fields: [userId], references: [id])
  package       RfqCreditPackage?      @relation(fields: [packageId], references: [id])
  revenueLedger PlatformRevenueLedger? @relation(fields: [revenueLedgerId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([packageId])
  @@index([revenueLedgerId])
  @@index([type])
}

