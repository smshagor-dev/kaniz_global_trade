  revenueReversalChildren RevenueReversalLedger[] @relation("ReversalGeneratedLedger")

  @@index([sourceType, sourceId])
  @@index([userId])
  @@index([companyId])
  @@index([orderId])
  @@index([tradeOrderId])
  @@index([sampleOrderId])
  @@index([paymentId])
  @@index([status])
  @@index([revenueType])
  @@index([taxSettingId])
  @@index([parentLedgerId])
}

