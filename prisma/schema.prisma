model FeeCalculationSnapshot {
  id                  String               @id @default(uuid())
  code                String
  sourceType          String
  sourceId            String
  userId              String?
  companyId           String?
  orderId             String?
  tradeOrderId        String?
  sampleOrderId       String?
  paymentId           String?
  serviceFeeSettingId String?
  revenueLedgerId     String?
  baseAmount          Decimal              @db.Decimal(15, 2)
  feeAmount           Decimal              @db.Decimal(15, 2)
  taxAmount           Decimal              @default(0) @db.Decimal(15, 2)
  totalAmount         Decimal              @db.Decimal(15, 2)
  currency            String               @default("USD")
  calculationData     String               @db.LongText
  createdAt           DateTime             @default(now())

  user             User?                  @relation(fields: [userId], references: [id])
  company          Company?               @relation(fields: [companyId], references: [id])
  tradeOrder       TradeOrder?            @relation(fields: [tradeOrderId], references: [id])
  sampleOrder      SampleOrder?           @relation(fields: [sampleOrderId], references: [id])
  payment          Payment?               @relation(fields: [paymentId], references: [id])
  serviceFee       ServiceFeeSetting?     @relation(fields: [serviceFeeSettingId], references: [id])
  revenueLedger    PlatformRevenueLedger? @relation(fields: [revenueLedgerId], references: [id])
  escrowTransactions EscrowTransaction[]
  shippingCommissions ShippingCommission[]
  verificationRequests VerificationRequest[]
  inspectionRequests InspectionRequest[]
  insuranceRequests InsuranceRequest[]
  tradeDocumentRequests TradeDocumentRequest[]
  complianceServiceRequests ComplianceServiceRequest[]
  sampleOrderFees SampleOrderFee[]

  @@index([code])
  @@index([sourceType, sourceId])
  @@index([userId])
  @@index([companyId])
  @@index([orderId])
  @@index([tradeOrderId])
  @@index([sampleOrderId])
  @@index([paymentId])
  @@index([serviceFeeSettingId])
  @@index([revenueLedgerId])
}

model DisputeCase {
  id                  String                   @id @default(uuid())
  companyId           String?
  chargedCompanyId    String?
  tradeOrderId        String?
  sampleOrderId       String?
  paymentId           String?
  revenueLedgerId     String?
  serviceFeeSettingId String?
  openedById          String
  assignedToId        String?
  disputeType         String
  disputeReason       String
  status              DisputeCaseStatus       @default(OPEN)
  payer               DisputePayer            @default(NONE)
  feeAmount           Decimal                 @default(0) @db.Decimal(15, 2)
  refundAmount        Decimal                 @default(0) @db.Decimal(15, 2)
  penaltyAmount       Decimal                 @default(0) @db.Decimal(15, 2)
  resolutionResult    DisputeResolutionResult?
  currency            String                  @default("USD")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  company        Company?               @relation("DisputeCompany", fields: [companyId], references: [id])
  chargedCompany Company?               @relation("DisputeChargedCompany", fields: [chargedCompanyId], references: [id])
  tradeOrder     TradeOrder?            @relation(fields: [tradeOrderId], references: [id])
  sampleOrder    SampleOrder?           @relation(fields: [sampleOrderId], references: [id])
  payment        Payment?               @relation(fields: [paymentId], references: [id])
  revenueLedger  PlatformRevenueLedger? @relation(fields: [revenueLedgerId], references: [id])
  serviceFee     ServiceFeeSetting?     @relation(fields: [serviceFeeSettingId], references: [id])
  openedBy       User                   @relation("DisputeOpenedBy", fields: [openedById], references: [id])
  assignedTo     User?                  @relation("DisputeAssignedTo", fields: [assignedToId], references: [id])
  evidence       DisputeEvidence[]
  resolutions    DisputeResolution[]
  refundRequests RefundRequest[]

  @@index([companyId])
  @@index([chargedCompanyId])
  @@index([tradeOrderId])
  @@index([sampleOrderId])
  @@index([paymentId])
  @@index([revenueLedgerId])
  @@index([serviceFeeSettingId])
  @@index([openedById])
  @@index([assignedToId])
  @@index([status])
}

model DisputeEvidence {
  id            String   @id @default(uuid())
  disputeCaseId String
  uploadedById  String
  title         String?
  fileUrl       String   @db.Text
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  disputeCase DisputeCase @relation(fields: [disputeCaseId], references: [id])
  uploadedBy  User        @relation("DisputeEvidenceUploadedBy", fields: [uploadedById], references: [id])

  @@index([disputeCaseId])
  @@index([uploadedById])
}

model DisputeResolution {
  id            String                  @id @default(uuid())
  disputeCaseId String
  resolvedById  String
  result        DisputeResolutionResult
  summary       String?                 @db.Text
  refundAmount  Decimal                 @default(0) @db.Decimal(15, 2)
  penaltyAmount Decimal                 @default(0) @db.Decimal(15, 2)
  createdAt     DateTime                @default(now())

  disputeCase DisputeCase @relation(fields: [disputeCaseId], references: [id])
  resolvedBy  User        @relation("DisputeResolvedBy", fields: [resolvedById], references: [id])

  @@index([disputeCaseId])
  @@index([resolvedById])
}

model RefundRequest {
  id                    String               @id @default(uuid())
  paymentId             String
  companyId             String?
  disputeCaseId         String?
  revenueLedgerId       String?
  requestedById         String
  reviewedById          String?
  status                RefundRequestStatus  @default(PENDING)
  originalPaidAmount    Decimal              @db.Decimal(15, 2)
  refundableAmount      Decimal              @db.Decimal(15, 2)
  nonRefundableFee      Decimal              @default(0) @db.Decimal(15, 2)
  gatewayFeeLoss        Decimal              @default(0) @db.Decimal(15, 2)
  supplierAdjustment    Decimal              @default(0) @db.Decimal(15, 2)
  approvedAmount        Decimal              @default(0) @db.Decimal(15, 2)
  currency              String               @default("USD")
  reason                String?              @db.Text
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  payment       Payment                @relation(fields: [paymentId], references: [id])
  company       Company?               @relation(fields: [companyId], references: [id])
  disputeCase   DisputeCase?           @relation(fields: [disputeCaseId], references: [id])
  revenueLedger PlatformRevenueLedger? @relation(fields: [revenueLedgerId], references: [id])
  requestedBy   User                   @relation("RefundRequestedBy", fields: [requestedById], references: [id])
  reviewedBy    User?                  @relation("RefundReviewedBy", fields: [reviewedById], references: [id])
  reversalLedgers RevenueReversalLedger[]

  @@index([paymentId])
  @@index([companyId])
  @@index([disputeCaseId])
  @@index([revenueLedgerId])
  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
}

model ChargebackCase {
  id                    String             @id @default(uuid())
  paymentId             String
  companyId             String?
  revenueLedgerId       String?
  openedById            String
  status                ChargebackStatus   @default(OPEN)
  originalPaidAmount    Decimal            @db.Decimal(15, 2)
  refundableAmount      Decimal            @default(0) @db.Decimal(15, 2)
  nonRefundableFee      Decimal            @default(0) @db.Decimal(15, 2)
