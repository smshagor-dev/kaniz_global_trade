// Prisma Schema - Kaniz Global Trade B2B Marketplace
// Multi-tenant, multi-company, production-ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

