  supplierAdjustment    Decimal            @default(0) @db.Decimal(15, 2)
  notes                 String?            @db.Text
  currency              String             @default("USD")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  payment       Payment                @relation(fields: [paymentId], references: [id])
  company       Company?               @relation(fields: [companyId], references: [id])
  revenueLedger PlatformRevenueLedger? @relation(fields: [revenueLedgerId], references: [id])
  openedBy      User                   @relation("ChargebackOpenedBy", fields: [openedById], references: [id])
  reversalLedgers RevenueReversalLedger[]

  @@index([paymentId])
  @@index([companyId])
  @@index([revenueLedgerId])
  @@index([openedById])
  @@index([status])
}

model TaxVatSetting {
  id                String               @id @default(uuid())
  code              String               @unique
  country           String
  stateRegion       String?
  taxName           String
  taxRate           Decimal              @db.Decimal(8, 4)
  taxType           TaxType
  applicationMode   TaxApplicationMode   @default(EXCLUSIVE)
  appliesToBuyer    Boolean              @default(true)
  appliesToSupplier Boolean              @default(false)
  appliesToServiceFee Boolean            @default(true)
  appliesToSubscription Boolean          @default(true)
  isActive          Boolean              @default(true)
  updatedById       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  updatedBy       User?                   @relation("TaxVatUpdatedBy", fields: [updatedById], references: [id])
  platformRevenueLedgers PlatformRevenueLedger[]
  taxSnapshots    TaxCalculationSnapshot[]

  @@index([country])
  @@index([stateRegion])
  @@index([isActive])
  @@index([updatedById])
}

model TaxCalculationSnapshot {
  id               String               @id @default(uuid())
  sourceType       String
  sourceId         String
  userId           String?
  paymentId        String?
  revenueLedgerId  String?
  taxSettingId     String?
  baseAmount       Decimal              @db.Decimal(15, 2)
  feeAmount        Decimal              @default(0) @db.Decimal(15, 2)
  taxAmount        Decimal              @db.Decimal(15, 2)
  totalAmount      Decimal              @db.Decimal(15, 2)
  currency         String               @default("USD")
  snapshotData     String               @db.LongText
  createdAt        DateTime             @default(now())

  user          User?                  @relation(fields: [userId], references: [id])
  payment       Payment?               @relation(fields: [paymentId], references: [id])
  revenueLedger PlatformRevenueLedger? @relation(fields: [revenueLedgerId], references: [id])
  taxSetting    TaxVatSetting?         @relation(fields: [taxSettingId], references: [id])

  @@index([sourceType, sourceId])
  @@index([userId])
  @@index([paymentId])
  @@index([revenueLedgerId])
  @@index([taxSettingId])
}

model RevenueReversalLedger {
  id                 String               @id @default(uuid())
  originalLedgerId   String
  reversalLedgerId   String?
  paymentId          String?
  refundRequestId    String?
  chargebackCaseId   String?
  companyId          String?
  createdById        String?
  amount             Decimal              @db.Decimal(15, 2)
  currency           String               @default("USD")
  reason             String?              @db.Text
  createdAt          DateTime             @default(now())

  originalLedger PlatformRevenueLedger @relation("ReversalOriginalLedger", fields: [originalLedgerId], references: [id])
  reversalLedger PlatformRevenueLedger? @relation("ReversalGeneratedLedger", fields: [reversalLedgerId], references: [id])
  payment       Payment?               @relation(fields: [paymentId], references: [id])
  refundRequest RefundRequest?         @relation(fields: [refundRequestId], references: [id])
  chargebackCase ChargebackCase?       @relation(fields: [chargebackCaseId], references: [id])
  company       Company?               @relation(fields: [companyId], references: [id])
  createdBy     User?                  @relation("RevenueReversalCreatedBy", fields: [createdById], references: [id])

  @@index([originalLedgerId])
  @@index([reversalLedgerId])
  @@index([paymentId])
  @@index([refundRequestId])
  @@index([chargebackCaseId])
  @@index([companyId])
  @@index([createdById])
}

// ============================================================
// ANALYTICS MODELS
// ============================================================

model CompanyAnalytic {
  id           String   @id @default(uuid())
  companyId    String
  date         DateTime @db.Date
  profileViews Int      @default(0)
  productViews Int      @default(0)
  inquiries    Int      @default(0)
  rfqs         Int      @default(0)
  messages     Int      @default(0)
  quotations   Int      @default(0)
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId])
  @@index([date])
}

model B2BCompany {
  id                         String                @id @default(uuid())
  userId                     String                @unique
  companyName                String
  legalName                  String?
  companyType                B2BCompanyType
  registrationNumber         String?
  taxNumber                  String?
  country                    String
  city                       String?
  address                    String?               @db.Text
  website                    String?
  phone                      String
  businessEmail              String
  description                String?               @db.Text
  logo                       String?
  tradeLicenseFile           String?
  taxDocumentFile            String?
  buyerVerificationStatus    B2BVerificationStatus @default(PENDING)
  buyerVerificationNote      String?               @db.Text
  buyerVerifiedAt            DateTime?
  buyerVerifiedBy            String?
  supplierVerificationStatus B2BVerificationStatus @default(PENDING)
  supplierVerificationNote   String?               @db.Text
  supplierVerifiedAt         DateTime?
  supplierVerifiedBy         String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  user                    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyerVerifiedByUser     User? @relation("B2BCompanyBuyerVerifiedBy", fields: [buyerVerifiedBy], references: [id])
  supplierVerifiedByUser  User? @relation("B2BCompanySupplierVerifiedBy", fields: [supplierVerifiedBy], references: [id])

  @@index([companyType])
  @@index([buyerVerificationStatus])
  @@index([supplierVerificationStatus])
  @@index([country])
  @@index([buyerVerifiedBy])
  @@index([supplierVerifiedBy])
}

model ProductAnalytic {
  id          String   @id @default(uuid())
  productId   String
  date        DateTime @db.Date
  views       Int      @default(0)
  inquiries   Int      @default(0)
  impressions Int      @default(0)
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId])
}
