// ============================================================
// AUTH & USER MODELS
// ============================================================

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  googleId         String?    @unique
  facebookId       String?    @unique
  emailVerified    DateTime?
  password         String
  firstName        String
  lastName         String
  phone            String?
  avatar           String?
  status           UserStatus @default(PENDING_VERIFICATION)
  twoFactorEnabled Boolean    @default(false)
  lastLoginAt      DateTime?
  lastLoginIp      String?
  fraudRiskScore   Int        @default(0)
  fraudRiskLevel   FraudRiskLevel @default(SAFE)
  fraudPublicFlag  FraudPublicFlag?
  fraudRestrictedActions String? @db.LongText
  fraudNotes       String?    @db.Text
  fraudLastReviewedAt DateTime?
  fraudLastNotifiedAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  // Relations
  roles             UserRole[]
  refreshTokens     RefreshToken[]
  emailTokens       EmailVerificationToken[]
  passwordResets    PasswordResetToken[]
  twoFactorSecret   TwoFactorSecret?
  companyUsers      CompanyUser[]
  inquiries         Inquiry[]                @relation("BuyerInquiries")
  rfqs              RFQ[]                    @relation("BuyerRFQs")
  chatParticipants  ChatParticipant[]
  messages          Message[]
  notifications     Notification[]
  notificationPrefs NotificationPreference?
  reviews           Review[]
  favoriteProducts  FavoriteProduct[]
  favoriteCompanies FavoriteCompany[]
  searchHistories   UserSearchHistory[]
  viewHistories     UserViewHistory[]
  auditLogs         AuditLog[]
  reports           Report[]                 @relation("ReportedBy")
  payments          Payment[]
  tradeOrders       TradeOrder[]             @relation("BuyerTradeOrders")
  sampleOrders      SampleOrder[]
  shipments         Shipment[]               @relation("BuyerShipments")
  escrowAccounts    EscrowAccount[]          @relation("BuyerEscrows")
  escrowDisputes    EscrowDispute[]          @relation("BuyerDisputes")
  tradeDocuments    TradeDocument[]
  kycProfile        KYCProfile?
  transactionRatingsGiven TransactionRating[]    @relation("RatingAuthor")
  transactionRatingsReceived TransactionRating[] @relation("RatingRecipient")
  fraudAlerts       FraudAlert[]             @relation("FraudReportedBy")
  fraudAlertsTargeted FraudAlert[]           @relation("FraudTargetUser")
  fraudAlertsReviewed FraudAlert[]           @relation("FraudReviewedByAdmin")
  fraudRiskHistories FraudRiskHistory[]      @relation("FraudUserHistory")
  fraudActorHistories FraudRiskHistory[]     @relation("FraudActorHistory")
  fraudReviewsTargeted FraudReview[]         @relation("FraudReviewedUser")
  fraudReviewsAuthored FraudReview[]         @relation("FraudReviewAdmin")
  fraudDeviceLogs    FraudDeviceLog[]
  creditProfile     CreditProfile?
  commissions       PlatformCommission[]
  financingRequests FinancingRequest[]
  logisticsBookings LogisticsBooking[]
  insurancePolicies InsurancePolicy[]
  insuranceClaims   InsuranceClaim[]        @relation("BuyerInsuranceClaims")
  contactMessages   ContactMessage[]
  newsletterSub     NewsletterSubscriber?
  categoriesCreated Category[]              @relation("CategoryCreatedBy")
  categoriesApproved Category[]             @relation("CategoryApprovedBy")
  subcategoriesCreated SubCategory[]        @relation("SubCategoryCreatedBy")
  subcategoriesApproved SubCategory[]       @relation("SubCategoryApprovedBy")
  platformRevenueLedgers PlatformRevenueLedger[]
  supplierPayoutLedgers SupplierPayoutLedger[] @relation("SupplierPayoutUser")
  verificationRequests VerificationRequest[] @relation("VerificationRequester")
  inspectionRequests InspectionRequest[] @relation("InspectionRequester")
  insuranceRequests InsuranceRequest[] @relation("InsuranceRequester")
  aiSubscriptions AiSubscription[]
  aiUsageLogs AiUsageLog[]
  rfqCreditWallets RfqCreditWallet[]
  rfqCreditTransactions RfqCreditTransaction[]
  tradeDocumentRequests TradeDocumentRequest[]
  complianceServiceRequests ComplianceServiceRequest[]
  sampleOrderFeeRecords SampleOrderFee[]
  feeCalculationSnapshots FeeCalculationSnapshot[]
  taxCalculationSnapshots TaxCalculationSnapshot[]
  disputeCasesOpened DisputeCase[] @relation("DisputeOpenedBy")
  disputeCasesAssigned DisputeCase[] @relation("DisputeAssignedTo")
  disputeEvidenceUploaded DisputeEvidence[] @relation("DisputeEvidenceUploadedBy")
  disputeResolutionsAuthored DisputeResolution[] @relation("DisputeResolvedBy")
  refundRequestsOpened RefundRequest[] @relation("RefundRequestedBy")
  refundRequestsReviewed RefundRequest[] @relation("RefundReviewedBy")
  chargebackCases ChargebackCase[] @relation("ChargebackOpenedBy")
  serviceFeeAuditEntries ServiceFeeSetting[] @relation("ServiceFeeUpdatedBy")
  taxVatAuditEntries TaxVatSetting[] @relation("TaxVatUpdatedBy")
  revenueReversalActions RevenueReversalLedger[] @relation("RevenueReversalCreatedBy")
  b2bCompanyOwned B2BCompany?
  buyerVerifiedCompanies B2BCompany[] @relation("B2BCompanyBuyerVerifiedBy")
  supplierVerifiedCompanies B2BCompany[] @relation("B2BCompanySupplierVerifiedBy")

  @@index([email])
  @@index([status])
  @@index([fraudRiskLevel])
  @@index([deletedAt])
}

enum UserViewEntityType {
  PRODUCT
  COMPANY
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorSecret {
  id          String   @id @default(uuid())
  userId      String   @unique
  secret      String
  backupCodes String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// COMPANY MODELS
// ============================================================

model Company {
  id                  String             @id @default(uuid())
  name                String
  legalName           String?
  slug                String             @unique
  logo                String?
  banner              String?
  businessType        BusinessType       @default(MANUFACTURER)
  registrationNumber  String?
  vatNumber           String?
  tradeLicenseNumber  String?
  exportLicenseNumber String?
  yearEstablished     Int?
  countryId           String?
  cityId              String?
  address             String?            @db.Text
  website             String?
  email               String?
  phone               String?
  whatsapp            String?
  mainProducts        String?            @db.Text
  description         String?            @db.LongText
  annualRevenue       String?
  employees           String?
  factorySize         String?
  productionCapacity  String?
  exportPercentage    Int?               @default(0)
  importPercentage    Int?               @default(0)
  status              CompanyStatus      @default(PENDING)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  isVerified          Boolean            @default(false)
  isFeatured          Boolean            @default(false)
  isPremium           Boolean            @default(false)
  totalViews          Int                @default(0)
  totalInquiries      Int                @default(0)
  fraudRiskScore      Int                @default(0)
  fraudRiskLevel      FraudRiskLevel     @default(SAFE)
  fraudPublicFlag     FraudPublicFlag?
  fraudRestrictedActions String?         @db.LongText
  fraudNotes          String?            @db.Text
  fraudLastReviewedAt DateTime?
  fraudLastNotifiedAt DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?

  // Relations
  country           Country?             @relation(fields: [countryId], references: [id])
  city              City?                @relation(fields: [cityId], references: [id])
  companyUsers      CompanyUser[]
  profile           CompanyProfile?
  gallery           CompanyGallery[]
  documents         CompanyDocument[]
  verification      CompanyVerification?
  certificates      CompanyCertificate[]
  factoryInfo       CompanyFactoryInfo?
  tradeInfo         CompanyTradeInfo?
  markets           CompanyMarket[]
  socialLinks       CompanySocialLink[]
  virtualTours      CompanyVirtualTour[]
  inspectionReports InspectionReport[]
  kycProfiles       KYCProfile[]
  products          Product[]
  inquiriesReceived Inquiry[]            @relation("SupplierInquiries")
  rfqQuotations     RFQQuotation[]
  chatRooms         ChatRoom[]
  subscription      Subscription?
  reviews           Review[]             @relation("CompanyReviews")
  favoriteBy        FavoriteCompany[]
  analytics         CompanyAnalytic[]
  viewHistories     UserViewHistory[]
  tradeOrders       TradeOrder[]         @relation("SupplierTradeOrders")
  sampleOrders      SampleOrder[]
  shipments         Shipment[]           @relation("SupplierShipments")
  escrowAccounts    EscrowAccount[]      @relation("SupplierEscrows")
  escrowDisputes    EscrowDispute[]      @relation("SupplierDisputes")
  transactionRatingsReceived TransactionRating[] @relation("CompanyRatingRecipient")
  fraudAlertsTargeted FraudAlert[]       @relation("FraudTargetCompany")
  fraudRiskHistories  FraudRiskHistory[] @relation("FraudCompanyHistory")
  fraudReviews        FraudReview[]      @relation("FraudReviewedCompany")
  creditProfile     CreditProfile?
  adCampaigns       AdCampaign[]
  financingRequests FinancingRequest[]
  logisticsBookings LogisticsBooking[]
  insurancePolicies InsurancePolicy[]
  insuranceClaims   InsuranceClaim[]
  commissions       PlatformCommission[]
  platformRevenueLedgers PlatformRevenueLedger[]
  verificationRequests VerificationRequest[]
  inspectionRequests InspectionRequest[]
  insuranceRequests InsuranceRequest[]
  aiSubscriptions AiSubscription[]
  rfqCreditWallets RfqCreditWallet[]
  tradeDocumentRequests TradeDocumentRequest[]
  complianceServiceRequests ComplianceServiceRequest[]
  sampleOrderFeeRecords SampleOrderFee[]
  feeCalculationSnapshots FeeCalculationSnapshot[]
  disputeCases DisputeCase[] @relation("DisputeCompany")
  chargebackCases ChargebackCase[]
  supplierPayoutLedgers SupplierPayoutLedger[]
  shippingCommissions ShippingCommission[]
  disputeFeeCases DisputeCase[] @relation("DisputeChargedCompany")
  refundRequests RefundRequest[]
  serviceFeeSettings ServiceFeeSetting[] @relation("ServiceFeeCompany")
  revenueReversalLedgers RevenueReversalLedger[]
  rfqMatchResults RfqMatchResult[]

  @@index([slug])
  @@index([status])
  @@index([verificationStatus])
  @@index([fraudRiskLevel])
  @@index([countryId])
  @@index([deletedAt])
  @@index([status, deletedAt, createdAt])
  @@index([status, verificationStatus, createdAt])
  @@index([countryId, status, createdAt])
}

model CompanyUser {
  id          String   @id @default(uuid())
  companyId   String
  userId      String
  title       String?
  permissions String?  @db.Text
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model CompanyProfile {
  id               String   @id @default(uuid())
  companyId        String   @unique
  overview         String?  @db.LongText
  advantages       String?  @db.Text
  missionStatement String?  @db.Text
  certifications   String?  @db.Text
  qualityControl   String?  @db.Text
  rndCapacity      String?  @db.Text
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyGallery {
  id        String   @id @default(uuid())
  companyId String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyDocument {
  id         String    @id @default(uuid())
  companyId  String
  type       String
  name       String
  url        String
  isPrivate  Boolean   @default(true)
  expiresAt  DateTime?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyVerification {
  id              String             @id @default(uuid())
  companyId       String             @unique
  status          VerificationStatus @default(UNVERIFIED)
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?            @db.Text
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyCertificate {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  issuedBy    String?
  issuedDate  DateTime?
  expiresAt   DateTime?
  documentUrl String?
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyFactoryInfo {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  factorySize         String?
  factoryLocation     String?
  productionLines     Int?
  qualityControlStaff Int?
  totalStaff          Int?
  annualOutput        String?
  updatedAt           DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyTradeInfo {
  id               String   @id @default(uuid())
  companyId        String   @unique
  mainMarkets      String?  @db.Text
  exportPercentage Int?
  importPercentage Int?
  nearestPort      String?
  bankName         String?
  bankAddress      String?
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyMarket {
  id        String   @id @default(uuid())
  companyId String
  countryId String
  type      String   @default("EXPORT")
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@unique([companyId, countryId, type])
}

model CompanySocialLink {
  id        String   @id @default(uuid())
  companyId String
  platform  String
  url       String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyVirtualTour {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  description String?  @db.Text
  videoUrl    String
  thumbnailUrl String?
  durationSec Int?
  language    String   @default("en")
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model InspectionReport {
  id            String           @id @default(uuid())
  companyId     String
  providerName  String
  inspectorName String?
  reportNumber  String           @unique
  score         Int?
  summary       String?          @db.Text
  findings      String?          @db.LongText
  reportUrl     String?
  reportStorageKey String?
  reportFilename String?
  reportMimeType String?
  adminReviewNotes String?       @db.Text
  inspectedAt   DateTime?
  verifiedAt    DateTime?
  status        InspectionStatus @default(REQUESTED)
  reviewedBy    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

// ============================================================
// PRODUCT MODELS
// ============================================================

model Product {
  id                 String        @id @default(uuid())
  companyId          String
  categoryId         String
  subcategoryId      String?
  name               String
  slug               String        @unique
  tags               String?       @db.Text
  shortDescription   String?       @db.Text
  description        String?       @db.LongText
  sku                String?
  barcode            String?
  thumbnailUrl       String?
  hsCodeId           String?
  moq                Decimal?      @db.Decimal(15, 2)
  moqUnit            String?
  unitTypeId         String?
  priceMin           Decimal?      @db.Decimal(15, 2)
  priceMax           Decimal?      @db.Decimal(15, 2)
  currencyId         String?
  priceNegotiable    Boolean       @default(true)
  productionCapacity String?
  leadTime           String?
  packagingDetails   String?       @db.Text
  status             ProductStatus @default(DRAFT)
  isFeatured         Boolean       @default(false)
  isTodaysDeal       Boolean       @default(false)
  isVerified         Boolean       @default(false)
  totalViews         Int           @default(0)
  totalInquiries     Int           @default(0)
  approvedAt         DateTime?
  approvedBy         String?
  rejectedReason     String?       @db.Text
  seoTitle           String?
  seoDescription     String?       @db.Text
  seoKeywords        String?       @db.Text
  seoImageUrl        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  // Relations
  company         Company                 @relation(fields: [companyId], references: [id])
  category        Category                @relation(fields: [categoryId], references: [id])
  subcategory     SubCategory?            @relation(fields: [subcategoryId], references: [id])
  hsCode          HsCode?                 @relation(fields: [hsCodeId], references: [id])
  unitType        UnitType?               @relation(fields: [unitTypeId], references: [id])
  currency        Currency?               @relation(fields: [currencyId], references: [id])
  images          ProductImage[]
  videos          ProductVideo[]
  variants        ProductVariant[]
  specifications  ProductSpecification[]
  documents       ProductDocument[]
  certificates    ProductCertificate[]
  priceTiers      ProductPriceTier[]
  exportMarkets   ProductExportMarket[]
  shippingMethods ProductShippingMethod[]
  paymentTerms    ProductPaymentTerm[]
  tradeTerms      ProductTradeTerm[]
  sampleOrders    SampleOrder[]
  insurancePolicies InsurancePolicy[]
  inquiries       Inquiry[]
  favorites       FavoriteProduct[]
  analytics       ProductAnalytic[]
  viewHistories   UserViewHistory[]
  adCampaigns     AdCampaign[]
  transactionRatings TransactionRating[]
  rfqMatchResults RfqMatchResult[]

  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
  @@index([deletedAt])
  @@index([companyId, status, createdAt])
  @@index([categoryId, status, createdAt])
  @@index([status, deletedAt, createdAt])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVideo {
  id        String   @id @default(uuid())
  productId String
  url       String
  title     String?
  thumbnailUrl String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  name      String
  value     String
  sku       String?
  price     Decimal? @db.Decimal(15, 2)
  moq       Decimal? @db.Decimal(15, 2)
  stock     Int?
  imageUrl  String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSpecification {
  id        String   @id @default(uuid())
  productId String
  key       String
  value     String
  unit      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductDocument {
  id        String   @id @default(uuid())
  productId String
  name      String
  url       String
  type      String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductCertificate {
  id        String   @id @default(uuid())
  productId String
  name      String
  url       String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductPriceTier {
  id        String   @id @default(uuid())
  productId String
  minQty    Decimal  @db.Decimal(15, 2)
  maxQty    Decimal? @db.Decimal(15, 2)
  price     Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductExportMarket {
  id        String   @id @default(uuid())
  productId String
  countryId String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id])

  @@unique([productId, countryId])
}

model ProductShippingMethod {
  id               String   @id @default(uuid())
  productId        String
  shippingMethodId String
  createdAt        DateTime @default(now())

  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  shippingMethod ShippingMethod @relation(fields: [shippingMethodId], references: [id])

  @@unique([productId, shippingMethodId])
}

model ProductPaymentTerm {
  id            String   @id @default(uuid())
  productId     String
  paymentTermId String
  createdAt     DateTime @default(now())

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  paymentTerm PaymentTerm @relation(fields: [paymentTermId], references: [id])

  @@unique([productId, paymentTermId])
}

model ProductTradeTerm {
  id          String   @id @default(uuid())
  productId   String
  tradeTermId String
  createdAt   DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  tradeTerm TradeTerm @relation(fields: [tradeTermId], references: [id])

  @@unique([productId, tradeTermId])
}

// ============================================================
// REFERENCE DATA MODELS
// ============================================================

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  icon        String?
  image       String?
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  approvalStatus CategoryApprovalStatus @default(APPROVED)
  source      CategorySource @default(ADMIN)
  createdById String?
  approvedById String?
  approvedAt  DateTime?
  rejectedReason String? @db.Text
  seoTitle    String?
  seoDesc     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

    parent        Category?     @relation("CategoryTree", fields: [parentId], references: [id])
    children      Category[]    @relation("CategoryTree")
    createdBy     User?         @relation("CategoryCreatedBy", fields: [createdById], references: [id])
    approvedBy    User?         @relation("CategoryApprovedBy", fields: [approvedById], references: [id])
    subcategories SubCategory[]
    products      Product[]
    rfqs          RFQ[]

    @@index([slug])
    @@index([parentId])
    @@index([approvalStatus])
    @@index([createdById])
  }

model SubCategory {
  id          String   @id @default(uuid())
  categoryId  String
  name        String
  slug        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  approvalStatus CategoryApprovalStatus @default(APPROVED)
  source      CategorySource @default(ADMIN)
  createdById String?
  approvedById String?
  approvedAt  DateTime?
  rejectedReason String? @db.Text
  createdAt   DateTime @default(now())

  category   Category  @relation(fields: [categoryId], references: [id])
  createdBy  User?     @relation("SubCategoryCreatedBy", fields: [createdById], references: [id])
  approvedBy User?     @relation("SubCategoryApprovedBy", fields: [approvedById], references: [id])
  products   Product[]

  @@index([categoryId])
  @@index([approvalStatus])
  @@index([createdById])
}

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  dialCode  String?
  flag      String?
  continent String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  cities               City[]
  ports                Port[]
  companies            Company[]
  companyMarkets       CompanyMarket[]
  productExports       ProductExportMarket[]
  rfqs                 RFQ[]
  inquiries            Inquiry[]
  shipmentOrigins      Shipment[]            @relation("ShipmentOriginCountry")
  shipmentDestinations Shipment[]            @relation("ShipmentDestinationCountry")
}

model City {
  id        String   @id @default(uuid())
  countryId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  country   Country   @relation(fields: [countryId], references: [id])
  companies Company[]

  @@index([countryId])
}

model Port {
  id        String   @id @default(uuid())
  countryId String
  name      String
  code      String?
  type      String   @default("SEA")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  country Country @relation(fields: [countryId], references: [id])

  @@index([countryId])
}

model HsCode {
  id          String   @id @default(uuid())
  code        String   @unique
  description String   @db.Text
  chapter     String?
  heading     String?
  subheading  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  products Product[]
}

model TradeTerm {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  productTradeTerms ProductTradeTerm[]
}

model PaymentTerm {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  productPaymentTerms ProductPaymentTerm[]
  quotations          RFQQuotation[]
}

model ShippingMethod {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  productShipping ProductShippingMethod[]
}

model Currency {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  symbol    String
  rate      Decimal  @default(1) @db.Decimal(15, 6)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  rfqs     RFQ[]
}

model UnitType {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]
}

// ============================================================
// INQUIRY SYSTEM
// ============================================================

model Inquiry {
  id                   String        @id @default(uuid())
  buyerId              String
  companyId            String
  productId            String?
  subject              String
  quantity             String?
  targetPrice          String?
  destinationCountryId String?
  message              String        @db.LongText
  status               InquiryStatus @default(OPEN)
  isRead               Boolean       @default(false)
  chatRoomId           String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deletedAt            DateTime?

  buyer              User                @relation("BuyerInquiries", fields: [buyerId], references: [id])
  company            Company             @relation("SupplierInquiries", fields: [companyId], references: [id])
  product            Product?            @relation(fields: [productId], references: [id])
  destinationCountry Country?            @relation(fields: [destinationCountryId], references: [id])
  attachments        InquiryAttachment[]
  replies            InquiryReply[]
  chatRoom           ChatRoom?           @relation(fields: [chatRoomId], references: [id])
  quotations         RFQQuotation[]

  @@index([buyerId])
  @@index([companyId])
  @@index([status])
  @@index([deletedAt])
}

model InquiryAttachment {
  id        String   @id @default(uuid())
  inquiryId String
  url       String
  name      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model InquiryReply {
  id        String   @id @default(uuid())
  inquiryId String
  senderId  String
  message   String   @db.LongText
  createdAt DateTime @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

// ============================================================
// RFQ SYSTEM
// ============================================================

model RFQ {
  id                   String    @id @default(uuid())
  buyerId              String
  categoryId           String?
  productName          String
  quantity             String
  unit                 String?
  destinationCountryId String?
  budget               Decimal?  @db.Decimal(15, 2)
  currencyId           String?
  requiredDate         DateTime?
  description          String?   @db.LongText
  status               RFQStatus @default(OPEN)
  expiresAt            DateTime?
  isPublic             Boolean   @default(true)
  viewCount            Int       @default(0)
  quotationCount       Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  buyer              User            @relation("BuyerRFQs", fields: [buyerId], references: [id])
  category           Category?       @relation(fields: [categoryId], references: [id])
  destinationCountry Country?        @relation(fields: [destinationCountryId], references: [id])
  currency           Currency?       @relation(fields: [currencyId], references: [id])
  attachments        RFQAttachment[]
  quotations         RFQQuotation[]
  matchSnapshots     RfqMatchSnapshot[]
  matchResults       RfqMatchResult[]

  @@index([buyerId])
  @@index([status])
  @@index([deletedAt])
  @@index([buyerId, status, createdAt])
  @@index([status, isPublic, expiresAt])
  @@index([categoryId, status, createdAt])
}

model RfqMatchSnapshot {
  id                String   @id @default(uuid())
  rfqId             String
  status            String   @default("READY")
  strategy          String   @default("DETERMINISTIC")
  usedAi            Boolean  @default(false)
  providersUsed     String?  @db.Text
  summary           String?  @db.Text
  rfqSignals        String?  @db.Text
  candidateCount    Int      @default(0)
  matchCount        Int      @default(0)
  generatedAt       DateTime @default(now())
  expiresAt         DateTime?
  errorMessage      String?  @db.Text

  rfq               RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  results           RfqMatchResult[]

  @@index([rfqId])
  @@index([generatedAt])
  @@index([expiresAt])
}

model RfqMatchResult {
  id                  String   @id @default(uuid())
  snapshotId          String
  rfqId               String
  companyId           String
  productId           String
  rank                Int
  score               Int
  baseScore           Int      @default(0)
  aiScoreBonus        Int      @default(0)
  keywordOverlap      Int      @default(0)
  destinationMatch    Boolean  @default(false)
  verifiedSupplier    Boolean  @default(false)
  premiumSupplier     Boolean  @default(false)
  signalMatches       String?  @db.Text
  reasons             String?  @db.LongText
  createdAt           DateTime @default(now())

  snapshot            RfqMatchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  rfq                 RFQ              @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  company             Company          @relation(fields: [companyId], references: [id])
  product             Product          @relation(fields: [productId], references: [id])

  @@unique([snapshotId, companyId])
  @@index([snapshotId, rank])
  @@index([rfqId])
  @@index([companyId])
  @@index([productId])
}

model RFQAttachment {
  id        String   @id @default(uuid())
  rfqId     String
  url       String
  name      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  rfq RFQ @relation(fields: [rfqId], references: [id], onDelete: Cascade)
}

model RFQQuotation {
  id             String          @id @default(uuid())
  rfqId          String?
  inquiryId      String?
  companyId      String
  buyerId        String
  totalPrice     Decimal         @db.Decimal(15, 2)
  currencyCode   String          @default("USD")
  deliveryTime   String?
  paymentTermId  String?
  shippingTerms  String?
  validUntil     DateTime?
  notes          String?         @db.LongText
  status         QuotationStatus @default(SENT)
  viewedAt       DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  rejectedReason String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  rfq         RFQ?                     @relation(fields: [rfqId], references: [id])
  inquiry     Inquiry?                 @relation(fields: [inquiryId], references: [id])
  company     Company                  @relation(fields: [companyId], references: [id])
  paymentTerm PaymentTerm?             @relation(fields: [paymentTermId], references: [id])
  items       RFQQuotationItem[]
  attachments RFQQuotationAttachment[]
  tradeOrder  TradeOrder?

  @@index([rfqId])
  @@index([inquiryId])
  @@index([companyId])
  @@index([status])
  @@index([buyerId])
  @@index([companyId, status, createdAt])
  @@index([rfqId, companyId])
}

model RFQQuotationItem {
  id          String  @id @default(uuid())
  quotationId String
  description String
  quantity    Decimal @db.Decimal(15, 2)
  unit        String?
  unitPrice   Decimal @db.Decimal(15, 2)
  totalPrice  Decimal @db.Decimal(15, 2)
  notes       String?

  quotation RFQQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model RFQQuotationAttachment {
  id          String   @id @default(uuid())
  quotationId String
  url         String
  name        String
  size        Int?
  mimeType    String?
  createdAt   DateTime @default(now())

  quotation RFQQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

// ============================================================
// CHAT SYSTEM
// ============================================================

model ChatRoom {
  id          String    @id @default(uuid())
  name        String?
  isGroup     Boolean   @default(false)
  companyId   String?
  inquiryId   String?
  lastMessage String?   @db.Text
  lastMsgAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company      Company?          @relation(fields: [companyId], references: [id])
  inquiries    Inquiry[]
  participants ChatParticipant[]
  messages     Message[]

  @@index([companyId])
}

model ChatParticipant {
  id         String    @id @default(uuid())
  roomId     String
  userId     String
  isAdmin    Boolean   @default(false)
  isBlocked  Boolean   @default(false)
  lastReadAt DateTime?
  joinedAt   DateTime  @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

model Message {
  id        String      @id @default(uuid())
  roomId    String
  senderId  String
  content   String?     @db.LongText
  type      MessageType @default(TEXT)
  isEdited  Boolean     @default(false)
  isDeleted Boolean     @default(false)
  replyToId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  room         ChatRoom             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender       User                 @relation(fields: [senderId], references: [id])
  attachments  MessageAttachment[]
  readReceipts MessageReadReceipt[]

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
  @@index([roomId, isDeleted, createdAt])
}

model MessageAttachment {
  id        String   @id @default(uuid())
  messageId String
  url       String
  name      String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ============================================================
// NOTIFICATION SYSTEM
// ============================================================

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  data      String?          @db.Text
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead, createdAt])
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  inquiryNotif Boolean  @default(true)
  rfqNotif     Boolean  @default(true)
  quoteNotif   Boolean  @default(true)
  messageNotif Boolean  @default(true)
  productNotif Boolean  @default(true)
  paymentNotif Boolean  @default(true)
  systemNotif  Boolean  @default(true)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KYCProfile {
  id                    String    @id @default(uuid())
  userId                String    @unique
  companyId             String?
  legalName             String?
  identityDocumentType  String?
  passportNumber        String?
  nationalIdNumber      String?
  personalCountry       String?
  personalCity          String?
  personalPostalCode    String?
  personalAddress       String?   @db.Text
  businessLicenseNumber String?
  bankAccountName       String?
  bankAccountNumber     String?
  bankName              String?
  bankAccountType       String?
  bankCurrency          String?
  bankBranchName        String?
  bankBranchCode        String?
  bankRoutingNumber     String?
  bankSwiftCode         String?
  bankIban              String?
  bankCountry           String?
  bankCity              String?
  bankAddress           String?   @db.Text
  documentUrls          String?   @db.LongText
  notes                 String?   @db.Text
  riskLevel             String?   @default("MEDIUM")
  transactionLimit      Decimal?  @db.Decimal(15, 2)
  status                KYCStatus @default(DRAFT)
  submittedAt           DateTime?
  reviewedAt            DateTime?
  reviewedBy            String?
  rejectionReason       String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([status])
  @@index([companyId])
}

// ============================================================
// SUBSCRIPTION & PAYMENT SYSTEM
// ============================================================

model SubscriptionPlan {
  id                   String   @id @default(uuid())
  name                 String   @unique
  slug                 String   @unique
  description          String?  @db.Text
  monthlyPrice         Decimal  @db.Decimal(10, 2)
  yearlyPrice          Decimal  @db.Decimal(10, 2)
  trialDays            Int      @default(0)
  maxProducts          Int      @default(10)
  maxStaff             Int      @default(1)
  maxImages            Int      @default(5)
  featuredProducts     Boolean  @default(false)
  featuredCompany      Boolean  @default(false)
  verificationBadge    Boolean  @default(false)
  analytics            Boolean  @default(false)
  priorityRanking      Boolean  @default(false)
  apiAccess            Boolean  @default(false)
  dedicatedSupport     Boolean  @default(false)
  isActive             Boolean  @default(true)
  isDefault            Boolean  @default(false)
  sortOrder            Int      @default(0)
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

