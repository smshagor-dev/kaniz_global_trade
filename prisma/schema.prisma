  status              RevenueLedgerStatus  @default(PENDING)
  revenueType         RevenueType          @default(CREDIT)
  refundableAmount    Decimal              @default(0) @db.Decimal(15, 2)
  nonRefundableAmount Decimal              @default(0) @db.Decimal(15, 2)
  taxAmount           Decimal              @default(0) @db.Decimal(15, 2)
  taxSettingId        String?
  parentLedgerId      String?
  notes               String?              @db.Text
  createdAt           DateTime             @default(now())

  user              User?                  @relation(fields: [userId], references: [id])
  company           Company?               @relation(fields: [companyId], references: [id])
  tradeOrder        TradeOrder?            @relation(fields: [tradeOrderId], references: [id])
  sampleOrder       SampleOrder?           @relation(fields: [sampleOrderId], references: [id])
  payment           Payment?               @relation(fields: [paymentId], references: [id])
  taxSetting        TaxVatSetting?         @relation(fields: [taxSettingId], references: [id])
  parentLedger      PlatformRevenueLedger? @relation("RevenueLedgerReversal", fields: [parentLedgerId], references: [id])
  reversalLedgers   PlatformRevenueLedger[] @relation("RevenueLedgerReversal")
  feeSnapshots      FeeCalculationSnapshot[]
  taxSnapshots      TaxCalculationSnapshot[]
  payoutLedgers     SupplierPayoutLedger[]
  verificationRequests VerificationRequest[]
  inspectionRequests InspectionRequest[]
  insuranceRequests InsuranceRequest[]
  aiSubscriptions     AiSubscription[]
  rfqCreditTransactions RfqCreditTransaction[]
  tradeDocumentRequests TradeDocumentRequest[]
  complianceServiceRequests ComplianceServiceRequest[]
